<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ndebele_icon_transparent"
            android:contentDescription="EduShelf Logo"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvEnquiryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send an Enquiry"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvSellerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seller: —"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etEnquiryName"
            style="@style/Input.Pill"
            android:layout_marginTop="0dp"
            android:hint="Your Name"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/etEnquiryEmail"
            style="@style/Input.Pill"
            android:layout_marginTop="12dp"
            android:hint="Your Email"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/etEnquiryMessage"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_rounded_gray"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:hint="Write your message to the seller..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnSendEnquiry"
            style="@style/Btn.Black"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:text="Send Enquiry" />

    </LinearLayout>
</ScrollView>