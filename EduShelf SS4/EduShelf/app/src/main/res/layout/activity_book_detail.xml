<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="textbook"
            type="com.example.edushelf.Textbook" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ndebele_icon_transparent"
                android:contentDescription="EduShelf Logo"
                android:scaleType="fitCenter"
                android:layout_gravity="center_horizontal" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="192dp"
                android:background="@drawable/bg_rounded_gray"
                android:layout_marginTop="20dp">
                <ImageView
                    android:id="@+id/iv_book_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ndebele_icon_transparent"
                    android:contentDescription="Book cover"
                    android:scaleType="centerInside"
                    android:alpha="0.3" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@{textbook.title}"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tvDetailPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@{textbook.formattedPrice()}"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E05050"
                android:layout_marginTop="4dp" />

            <LinearLayout style="@style/DetailRow" android:layout_marginTop="20dp">
                <TextView style="@style/DetailLabel" android:text="Author" />
                <TextView android:id="@+id/tvDetailAuthor" style="@style/DetailValue" android:text="@{textbook.author}" />
            </LinearLayout>

            <LinearLayout style="@style/DetailRow" android:layout_marginTop="8dp">
                <TextView style="@style/DetailLabel" android:text="Course" />
                <TextView android:id="@+id/tvDetailCourse" style="@style/DetailValue" android:text="@{textbook.course}" />
            </LinearLayout>

            <LinearLayout style="@style/DetailRow" android:layout_marginTop="8dp">
                <TextView style="@style/DetailLabel" android:text="Edition" />
                <TextView android:id="@+id/tvDetailEdition" style="@style/DetailValue" android:text="@{textbook.edition.isEmpty() ? `N/A` : textbook.edition}" />
            </LinearLayout>

            <LinearLayout style="@style/DetailRow" android:layout_marginTop="8dp">
                <TextView style="@style/DetailLabel" android:text="Condition" />
                <TextView android:id="@+id/tvDetailCondition" style="@style/DetailValue" android:text="@{textbook.condition}" />
            </LinearLayout>

            <LinearLayout style="@style/DetailRow" android:layout_marginTop="8dp">
                <TextView style="@style/DetailLabel" android:text="Seller" />
                <TextView android:id="@+id/tvDetailSeller" style="@style/DetailValue" android:text="@{textbook.sellerName}" />
            </LinearLayout>

            <Button
                android:id="@+id/btnContactSeller"
                style="@style/Btn.Outline"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:text="Contact seller" />

            <Button
                android:id="@+id/btnBuy"
                style="@style/Btn.Red"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:text="Buy book" />

        </LinearLayout>
    </ScrollView>
</layout>