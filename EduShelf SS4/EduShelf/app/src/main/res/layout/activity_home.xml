<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#FFFFFF"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="48dp"
    android:paddingBottom="40dp">

    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ndebele_icon_transparent"
        android:contentDescription="EduShelf Logo"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hey there, Student"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/btnGrabTextbook"
        style="@style/Btn.Outline"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:text="Grab a textbook" />

    <Button
        android:id="@+id/btnSell"
        style="@style/Btn.Black"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:text="Clear your shelf" />

    <Button
        android:id="@+id/btnProfile"
        style="@style/Btn.Outline"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:text="View my profile" />

    <Button
        android:id="@+id/btnDownload"
        style="@style/Btn.Outline"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:text="Download Android App" />

</LinearLayout>