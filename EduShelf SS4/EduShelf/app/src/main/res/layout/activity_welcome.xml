<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#FFFFFF"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="80dp"
    android:paddingBottom="40dp">

    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="128dp"
        android:layout_height="128dp"
        android:src="@drawable/ndebele_icon_transparent"
        android:contentDescription="EduShelf Logo"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/tv_welcome_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to EduShelf!"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buy, sell and save on textbooks in one place"
        android:textSize="15sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:id="@+id/ll_auth_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="40dp">

        <Button
            android:id="@+id/btnLogin"
            style="@style/Btn.Red"
            android:layout_width="130dp"
            android:layout_height="50dp"
            android:text="Login" />

        <Button
            android:id="@+id/btnRegister"
            style="@style/Btn.Outline"
            android:layout_width="130dp"
            android:layout_height="50dp"
            android:layout_marginStart="16dp"
            android:text="Register" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAlreadyAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Already have an account? Log in"
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:layout_marginTop="40dp" />

</LinearLayout>